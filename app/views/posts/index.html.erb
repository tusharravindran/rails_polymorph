<h1>All Posts</h1>

<% @posts.each do |post| %>
  <div>
    <h2><%= link_to post.title, post_path(post) %></h2>

    <p> By <%= post.user.email%><p>
    <p><%= post.content.truncate(100) %></p>
  </div>
<% end %>
<%= paginate @posts %>
<%= link_to "New Post", new_post_path, class: "btn btn-primary" if user_signed_in? %>
