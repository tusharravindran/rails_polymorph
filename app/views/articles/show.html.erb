<h1><%= @article.title %></h1>
<p><%= @article.content %></p>

<h3>Comments</h3>
<% @article.comments.each do |comment| %>
  <p><%= comment.content %> - <%= comment.user.email %></p>
<% end %>

<h3>Leave a comment:</h3>
<%= form_with model: [ @article, Comment.new ] do |form| %>
  <%= form.text_area :content %>
  <%= form.submit "Post Comment" %>
<% end %>
