<h1>Articles</h1>

<% @articles.each do |article| %>
  <div>
    <h2><%= link_to article.title, article_path(article) %></h2>
    <p><%= truncate(article.content, length: 100) %></p>
    <p><strong>By:</strong> <%= article.user.email %></p>
  </div>
  <hr>
<% end %>

<%= paginate @articles %>

<%= link_to "New Article", new_article_path, class: "btn btn-primary" if user_signed_in? %>
